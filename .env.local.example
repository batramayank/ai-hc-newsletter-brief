# ── Supabase ──────────────────────────────────────────────────────────────────
# Settings → API in your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# ── Site metadata ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://aihealthcarebrief.com

# ── SendGrid ──────────────────────────────────────────────────────────────────
# API key: Settings → API Keys → Create (Full Access or Marketing only)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# List UUIDs: Marketing → Lists (copy the ID from each list's URL or settings)
SENDGRID_UNVERIFIED_LIST_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SENDGRID_VERIFIED_LIST_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Custom field ID for the encrypted token (NOT the field name — the short ID like e1_T)
# Create it: Marketing → Custom Fields → Add Field → Name: email_encrypted, Type: Text
# The field ID appears in the field list after creation
SENDGRID_CUSTOM_FIELD_ID=e1_T

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte secret key for AES-256-GCM — generate with: openssl rand -hex 32
ENCRYPTION_SECRET=your_64_char_hex_string_here
